# CHIMERA cloud brain credentials — copy this file to  chimera.env  and fill in
# the values from your Neo4j Aura instance (see docs/NEO4J_SETUP.md).
#
# ⚠️  Never commit the real chimera.env — it holds your password. It's gitignored.

NEO4J_URI=neo4j+s://YOUR-INSTANCE-ID.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password-here

# Optional: name your collective mind (defaults to "The Collective")
# CHIMERA_COLLECTIVE_NAME=The Fractality Collective
